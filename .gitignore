# =============================================================================
# Sensitive / secrets — NEVER commit these
# =============================================================================

# Environment files
.env
.env.*
!.env.example

# Private keys, certificates, and credentials
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.jks
*.keystore

# Generic secret files
*.secret
secrets/
.secrets

# AWS credentials
.aws/
credentials

# GitHub App private keys (explicit safety net)
gh-app-private-key*
private-key*

# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# uv
backend/.venv/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage.xml
coverage.json

# =============================================================================
# Node / Frontend
# =============================================================================

frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/coverage/

# Frontend env files (mirror backend safety net)
frontend/.env
frontend/.env.*
!frontend/.env.example

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# =============================================================================
# Logs
# =============================================================================

*.log
logs/

# =============================================================================
# Databases (local dev)
# =============================================================================

*.sqlite
*.sqlite3
*.db

# =============================================================================
# Docker
# =============================================================================

.docker/
docker-compose.override.yml

# =============================================================================
# OS artifacts
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# =============================================================================
# Editor / IDE
# =============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
