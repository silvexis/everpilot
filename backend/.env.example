# Copy to .env and fill in values
APP_ENV=development
DEBUG=true

# GitHub App credentials (from https://github.com/settings/apps)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Security
SECRET_KEY=change-me-in-production

# Server
API_HOST=0.0.0.0
API_PORT=8000
